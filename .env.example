POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=postgres
POSTGRES_SSLMODE=disable
POSTGRES_CONNECT_RETRIES=3
POSTGRES_CONNECT_RETRY_INTERVAL=5s 
POSTGRES_STATEMENT_TIMEOUT=60000 
POSTGRES_APPLICATION_NAME=person-enrichment-service

MIGRATIONS_DIR=./migrations

PGX_POOL_MAX_CONNS=10
PGX_POOL_MIN_CONNS=2
PGX_CONNECT_TIMEOUT=10s  
PGX_POOL_ACQUIRE_TIMEOUT=60s
PGX_POOL_MAX_CONN_LIFETIME=3600 
PGX_POOL_MAX_CONN_IDLE_TIME=600


GRACEFUL_SHUTDOWN_TIMEOUT=5s

LOGGER_LEVEL=debug
LOGGER_FORMAT=json
LOGGER_OUTPUT=stdout
LOGGER_TIME_ENCODING=iso8601
LOGGER_CALLER=true
LOGGER_STACKTRACE=true
LOGGER_MODEL=development

HTTP_READ_TIMEOUT=5s
HTTP_WRITE_TIMEOUT=10s

HC_PG_INTERVAL=5s
HC_PG_TIMEOUT=5s
HC_PG_RETRIES=3

HC_NGINX_INTERVAL=30s
HC_NGINX_TIMEOUT=10s
HC_NGINX_RETRIES=5

HC_SERVICE_INTERVAL=30s
HC_SERVICE_TIMEOUT=5s
HC_SERVICE_START_PERIOD=5s
HC_SERVICE_RETRIES=3

BACKEND_HOST=service     
BACKEND_PORT=8080         
